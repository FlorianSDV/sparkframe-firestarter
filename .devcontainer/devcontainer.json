{
	"name": "Firestarter devcontainer",
	"dockerComposeFile": [
		"../docker-compose-dev.yml",
		"../docker-compose-mysql.yml"
	],
	"service": "sparkframe-firestarter-dev",
	"workspaceMount": "type=bind,source=${localWorkspaceFolder},target=/var/www/html",
	"workspaceFolder": "/var/www/html",
	"forwardPorts": [
		8000,
		9003
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"xdebug.php-debug",
				"bmewburn.vscode-intelephense-client",
				"ikappas.composer"
			]
		}
	},
	"features": {
		"ghcr.io/devcontainers/features/git:1": {}
	},
	"postCreateCommand": "git config --global --add safe.directory /var/www/html && composer create-sqlite-db && composer create-mysql-db"
}